# ── 环境与密钥（永远不提交） ──
.env
.env.*
!.env.example

# ── AI Agent 配置（本地工具，不入库） ──
CLAUDE.md
AGENTS.md
.gitnexus/

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.venv/
venv/
*.egg-info/
.eggs/
dist/
build/
*.egg
*.log
*.pid
.superpowers/

# ── 前端 ──
frontend/node_modules/
frontend/.vite/

# ── 本地 Agent / MCP 缓存 ──
.playwright-mcp/
.claude/
.trae/

# ── 覆盖率 / 测试产物 ──
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# ── 数据库 SQLite 副本 ──
*.db
*.db.backup
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── 应用运行时数据（保留目录结构，忽略内容） ──
data/novels/
data/foreshadowings/
data/bibles/bible-novel-*.json
data/bibles/novel-*-bible.json
data/bibles/bible-test-*.json
data/bibles/bible-final-*.json

# ── 书籍输出（仅保留占位文件） ──
output/novels/*/
!output/novels/.gitkeep

# ── 临时 / 生成的 API fixtures ──
interfaces/data/

# ── OS / 编辑器 ──
.DS_Store
Thumbs.db
Desktop.ini

# ── 本地向量 DB / 开发 dump ──
qdrant_storage/

# ── 本地模型文件（~2GB，按需下载） ──
.models/
frontend/node_modules/

# ── 评估结果 ──
scripts/evaluation/results/

# Local runtime environment artifacts
# 这些是本机启动、索引、日志、模型下载产生的内容，不应入库
data/chromadb/
data/qdrant_storage/
data/logs/
data/llm_configs.json
logs/
data/qdrant/

# ── PyInstaller 打包产物（根目录） ──
aitext.spec
aitext.lock
aitext.exe
aitext.pkg
Analysis-*.toc
COLLECT-*.toc
EXE-*.toc
PKG-*.toc
PYZ-*.toc
warn-*.txt
xref-*.html
localpycs/
base_library.zip

